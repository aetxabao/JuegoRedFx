<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.masanz.da.juegored.controller.PreGammeLobbyController">
    <top>
        <BorderPane prefHeight="119.0" prefWidth="665.0" style="-fx-background-color: #353535;" BorderPane.alignment="CENTER">
            <center>
                <ImageView fitHeight="100.0" fitWidth="600.0" pickOnBounds="true" BorderPane.alignment="CENTER">
                    <image>
                        <Image url="@imgs/logo.png" />
                    </image>
                </ImageView>
            </center>
        </BorderPane>
    </top>
   <bottom>
      <HBox alignment="CENTER" spacing="180.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#ready" text="Estoy listo" />
            <Button mnemonicParsing="false" onAction="#chatear" text="Chatear" />
            <Button mnemonicParsing="false" onAction="#abandonar" text="Abandonar" />
         </children>
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>
   <left>
      <TableView fx:id="tbvJugadores" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn prefWidth="117.0" text="Player" />
          <TableColumn prefWidth="65.0" text="Listo" />
        </columns>
      </TableView>
   </left>
   <right>
      <BorderPane BorderPane.alignment="CENTER">
         <center>
            <TextArea fx:id="txaChat" BorderPane.alignment="CENTER" />
         </center>
         <bottom>
            <TextField fx:id="txtMessage" BorderPane.alignment="CENTER" />
         </bottom>
      </BorderPane>
   </right>

</BorderPane>
