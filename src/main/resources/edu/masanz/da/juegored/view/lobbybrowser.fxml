<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.masanz.da.juegored.controller.LobbyBrowserController">
    <top>
        <BorderPane prefHeight="119.0" prefWidth="665.0" style="-fx-background-color: #353535;" BorderPane.alignment="CENTER">
            <center>
                <ImageView fitHeight="100.0" fitWidth="600.0" pickOnBounds="true" BorderPane.alignment="CENTER">
                    <image>
                        <Image url="@imgs/logo.png" />
                    </image>
                </ImageView>
            </center>
        </BorderPane>
    </top>
   <center>
      <TableView fx:id="tbvSalas" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colNombre" editable="false" prefWidth="120.0" resizable="false" style="-fx-text-align: center;" text="Nombre de sala" />
          <TableColumn fx:id="colJugadores" editable="false" prefWidth="120.0" resizable="false" text="Jugadores" />
            <TableColumn fx:id="colPrivacidad" editable="false" prefWidth="120.0" resizable="false" text="Privacidad" />
            <TableColumn fx:id="colDificultad" editable="false" prefWidth="120.0" resizable="false" text="Dificultad" />
            <TableColumn fx:id="colPing" editable="false" prefWidth="120.0" resizable="false" text="Ping" />
        </columns>
      </TableView>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#volver" text="Volver al menú" />
            <Button mnemonicParsing="false" onAction="#unir" text="Unirme a la sala seleccionada" />
            <Button mnemonicParsing="false" onAction="#crearSala" text="Crear nueva sala" />
         </children>
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>

</BorderPane>
